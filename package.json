{
  "name": "excel-practice-quiz",
  "version": "1.0.0",
  "description": "Add-in Ujian Praktik Excel Interaktif",
  "scripts": {
    "start": "node server.js",
    "dev": "node server.js",
    "build:config": "node scripts/generate-client-config.js",
    "vercel-build": "node scripts/generate-client-config.js",
    "manifest:set": "node scripts/update-manifest.js",
    "seed": "node scripts/seed-questions.js",
    "test": "node --test tests/unit/checkers.test.js tests/integration/supabase.test.js",
    "start:excel": "office-addin-debugging start manifest.xml desktop --app excel",
    "start:excel:file": "office-addin-debugging start manifest.xml desktop --app excel",
    "start:word": "office-addin-debugging start manifest.xml desktop --app word",
    "start:powerpoint": "office-addin-debugging start manifest.xml desktop --app powerpoint",
    "stop": "office-addin-debugging stop manifest.xml"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.105.1",
    "dotenv": "^17.4.2",
    "express": "^4.18.2",
    "https": "^1.0.0",
    "xendit-node": "^7.0.0"
  },
  "keywords": [
    "excel",
    "add-in",
    "quiz",
    "office"
  ],
  "author": "ExamQuiz",
  "license": "MIT",
  "devDependencies": {
    "office-addin-debugging": "^6.0.7",
    "office-addin-manifest": "^2.1.3"
  }
}
