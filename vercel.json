{
  "version": 2,
  "builds": [
    {
      "src": "package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "public"
      }
    },
    {
      "src": "api/**/*.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/shared/app-configuration/app.config.js",
      "dest": "/api/app-config"
    },
    {
      "src": "/app",
      "dest": "/features/participant-exam/taskpane.html"
    },
    {
      "src": "/login",
      "dest": "/features/participant-login/login.html"
    },
    {
      "src": "/admin/login",
      "dest": "/features/admin-login/admin-login.html"
    },
    {
      "src": "/admin/commands",
      "dest": "/features/admin-dashboard/commands.html"
    },
    {
      "src": "/admin",
      "dest": "/features/admin-dashboard/dashboard.html"
    },
    {
      "src": "/pages/participant/taskpane.html",
      "status": 308,
      "headers": {
        "Location": "/app"
      }
    },
    {
      "src": "/pages/participant/login.html",
      "status": 308,
      "headers": {
        "Location": "/login"
      }
    },
    {
      "src": "/pages/admin/admin-login.html",
      "status": 308,
      "headers": {
        "Location": "/admin/login"
      }
    },
    {
      "src": "/pages/admin/dashboard.html",
      "status": 308,
      "headers": {
        "Location": "/admin"
      }
    },
    {
      "src": "/pages/admin/commands.html",
      "status": 308,
      "headers": {
        "Location": "/admin/commands"
      }
    },
    {
      "src": "/taskpane.html",
      "status": 308,
      "headers": {
        "Location": "/app"
      }
    },
    {
      "src": "/login.html",
      "status": 308,
      "headers": {
        "Location": "/login"
      }
    },
    {
      "src": "/admin-login.html",
      "status": 308,
      "headers": {
        "Location": "/admin/login"
      }
    },
    {
      "src": "/dashboard.html",
      "status": 308,
      "headers": {
        "Location": "/admin"
      }
    },
    {
      "src": "/commands.html",
      "status": 308,
      "headers": {
        "Location": "/admin/commands"
      }
    },
    {
      "handle": "filesystem"
    },
    {
      "src": "/api/(.*)",
      "dest": "/api/index.js"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Access-Control-Allow-Origin",
          "value": "*"
        },
        {
          "key": "Access-Control-Allow-Methods",
          "value": "GET, OPTIONS"
        },
        {
          "key": "Access-Control-Allow-Headers",
          "value": "Content-Type"
        }
      ]
    },
    {
      "source": "/shared/app-configuration/app.config.js",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-store"
        }
      ]
    }
  ]
}