{
  "version": 2,
  "builds": [
    {
      "src": "package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "public"
      }
    },
    {
      "src": "api/**/*.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/js/config/app.config.js",
      "dest": "/api/app-config"
    },
    {
      "src": "/taskpane.html",
      "dest": "/pages/participant/taskpane.html"
    },
    {
      "src": "/login.html",
      "dest": "/pages/participant/login.html"
    },
    {
      "src": "/commands.html",
      "dest": "/pages/admin/commands.html"
    },
    {
      "src": "/dashboard.html",
      "dest": "/pages/admin/dashboard.html"
    },
    {
      "handle": "filesystem"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Access-Control-Allow-Origin",
          "value": "*"
        },
        {
          "key": "Access-Control-Allow-Methods",
          "value": "GET, OPTIONS"
        },
        {
          "key": "Access-Control-Allow-Headers",
          "value": "Content-Type"
        }
      ]
    },
    {
      "source": "/js/config/app.config.js",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-store"
        }
      ]
    }
  ]
}
